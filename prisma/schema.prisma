generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppLocale {
  EN @map("en")
  TH @map("th")

  @@map("app_locale")
}

enum WorkspaceRole {
  OWNER      @map("owner")
  ADMIN      @map("admin")
  SUPERVISOR @map("supervisor")
  AGENT      @map("agent")

  @@map("workspace_role")
}

enum MemberStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  INVITED  @map("invited")

  @@map("member_status")
}

enum InvitationStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  REVOKED  @map("revoked")
  EXPIRED  @map("expired")

  @@map("invitation_status")
}

enum PresenceStatus {
  ONLINE  @map("online")
  AWAY    @map("away")
  OFFLINE @map("offline")

  @@map("presence_status")
}

enum ChannelType {
  LINE        @map("line")
  FACEBOOK    @map("facebook")
  INSTAGRAM   @map("instagram")
  TELEGRAM    @map("telegram")
  X           @map("x")
  TIKTOK      @map("tiktok")
  SHOPEE      @map("shopee")
  LAZADA      @map("lazada")
  TIKTOK_SHOP @map("tiktok_shop")

  @@map("channel_type")
}

enum TagTarget {
  CUSTOMER     @map("customer")
  CONVERSATION @map("conversation")

  @@map("tag_target")
}

enum TagAssignmentSource {
  MANUAL     @map("manual")
  AUTOMATION @map("automation")
  IMPORT     @map("import")
  API        @map("api")

  @@map("tag_assignment_source")
}

enum ConversationStatus {
  OPEN     @map("open")
  PENDING  @map("pending")
  RESOLVED @map("resolved")

  @@map("conversation_status")
}

enum MessageDirection {
  INBOUND  @map("inbound")
  OUTBOUND @map("outbound")
  INTERNAL @map("internal")

  @@map("message_direction")
}

enum MessageType {
  TEXT  @map("text")
  IMAGE @map("image")
  NOTE  @map("note")
  FILE  @map("file")

  @@map("message_type")
}

enum AttachmentKind {
  IMAGE @map("image")
  FILE  @map("file")
  VIDEO @map("video")

  @@map("attachment_kind")
}

enum IntegrationProvider {
  LINE        @map("line")
  FACEBOOK    @map("facebook")
  INSTAGRAM   @map("instagram")
  TELEGRAM    @map("telegram")
  X           @map("x")
  TIKTOK      @map("tiktok")
  SHOPEE      @map("shopee")
  LAZADA      @map("lazada")
  TIKTOK_SHOP @map("tiktok_shop")

  @@map("integration_provider")
}

enum IntegrationCapability {
  INBOX      @map("inbox")
  PUBLISHING @map("publishing")

  @@map("integration_capability")
}

enum IntegrationStatus {
  CONNECTED    @map("connected")
  DISCONNECTED @map("disconnected")
  EXPIRED      @map("expired")
  ERROR        @map("error")
  COMING_SOON  @map("coming_soon")

  @@map("integration_status")
}

enum PublishingStatus {
  DRAFT     @map("draft")
  SCHEDULED @map("scheduled")
  PUBLISHED @map("published")
  FAILED    @map("failed")

  @@map("publishing_status")
}

enum PublishSubmitMode {
  DRAFT    @map("draft")
  PUBLISH  @map("publish")
  SCHEDULE @map("schedule")

  @@map("publish_submit_mode")
}

enum PublishingTargetStatus {
  PENDING   @map("pending")
  SCHEDULED @map("scheduled")
  PUBLISHED @map("published")
  FAILED    @map("failed")
  SKIPPED   @map("skipped")

  @@map("publishing_target_status")
}

enum OrderMarketplace {
  SHOPEE       @map("shopee")
  LAZADA       @map("lazada")
  TIKTOK_SHOP  @map("tiktok_shop")
  DIRECT_STORE @map("direct_store")

  @@map("order_marketplace")
}

enum OrderStatus {
  PENDING    @map("pending")
  PAID       @map("paid")
  PROCESSING @map("processing")
  SHIPPED    @map("shipped")
  DELIVERED  @map("delivered")
  CANCELLED  @map("cancelled")
  REFUNDED   @map("refunded")

  @@map("order_status")
}

enum WebhookEventStatus {
  PENDING   @map("pending")
  PROCESSED @map("processed")
  FAILED    @map("failed")

  @@map("webhook_event_status")
}

enum SegmentMatch {
  ALL @map("all")
  ANY @map("any")

  @@map("segment_match")
}

enum MarketingConsentStatus {
  UNKNOWN   @map("unknown")
  OPTED_IN  @map("opted_in")
  OPTED_OUT @map("opted_out")

  @@map("marketing_consent_status")
}

enum AuditActorType {
  USER    @map("user")
  SYSTEM  @map("system")
  WEBHOOK @map("webhook")

  @@map("audit_actor_type")
}

model Organization {
  id                        String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                      String                    @unique
  name                      String
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs                 AuditLog[]
  conversationAssignments   ConversationAssignment[]
  conversationMessages      ConversationMessage[]
  conversationTags          ConversationTag[]
  conversations             Conversation[]
  customerChannelIdentities CustomerChannelIdentity[]
  customerNotes             CustomerNote[]
  customerTags              CustomerTag[]
  customers                 Customer[]
  integrationCredentials    IntegrationCredential[]
  integrations              Integration[]
  invitations               Invitation[]
  invoiceLineItems          InvoiceLineItem[]
  invoices                  Invoice[]
  members                   Member[]
  messageAttachments        MessageAttachment[]
  orderItems                OrderItem[]
  orders                    Order[]
  profiles                  Profile[]
  publishingPosts           PublishingPost[]
  publishingTargets         PublishingTarget[]
  savedReplies              SavedReply[]
  tags                      Tag[]
  tagAuditLogs              TagAuditLog[]
  webhookEvents             WebhookEvent[]
  workspaceSettings         WorkspaceSettings?
  segments                  Segment[]
  segmentMemberships        SegmentMembership[]
  Campaign                  Campaign[]
  CampaignMessage           CampaignMessage[]
  CampaignBatch             CampaignBatch[]
  CampaignRecipient         CampaignRecipient[]
  CampaignAuditLog          CampaignAuditLog[]

  @@map("organizations")
}

model WorkspaceSettings {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String       @unique @map("organization_id") @db.Uuid
  businessName     String       @map("business_name")
  supportEmail     String       @map("support_email")
  supportPhone     String?      @map("support_phone")
  logoPreview      String?      @map("logo_preview")
  defaultLocale    AppLocale    @default(EN) @map("default_locale")
  timezone         String       @default("Asia/Bangkok")
  businessHours    Json         @map("business_hours")
  inboxPreferences Json         @map("inbox_preferences")
  notifications    Json
  slaTargetMinutes Int          @default(15) @map("sla_target_minutes")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model Profile {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  userId           String?      @unique @map("user_id") @db.Uuid
  email            String
  fullName         String       @map("full_name")
  avatarFallback   String?      @map("avatar_fallback")
  phone            String?
  localePreference AppLocale?   @map("locale_preference")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members          Member[]

  @@unique([organizationId, email])
  @@map("profiles")
}

model Member {
  id                         String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId             String                   @map("organization_id") @db.Uuid
  profileId                  String                   @map("profile_id") @db.Uuid
  role                       WorkspaceRole
  status                     MemberStatus             @default(ACTIVE)
  team                       String
  workloadLimit              Int                      @default(0) @map("workload_limit")
  onlineStatus               PresenceStatus           @default(OFFLINE) @map("online_status")
  lastActiveAt               DateTime?                @map("last_active_at") @db.Timestamptz(6)
  createdAt                  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedCustomers          Customer[]               @relation("CustomerAssignee")
  assignedConversations      Conversation[]           @relation("ConversationAssignee")
  authoredMessages           ConversationMessage[]    @relation("MessageSenderMember")
  authoredNotes              CustomerNote[]           @relation("CustomerNoteAuthor")
  authoredSavedReplies       SavedReply[]             @relation("SavedReplyAuthor")
  authoredPublishingPosts    PublishingPost[]         @relation("PublishingPostAuthor")
  organization               Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile                    Profile                  @relation(fields: [profileId], references: [id], onDelete: Restrict)
  invitationsSent            Invitation[]             @relation("InvitationInviter")
  assignments                ConversationAssignment[] @relation("AssignedMember")
  assignmentsCreated         ConversationAssignment[] @relation("AssigningMember")
  auditLogs                  AuditLog[]               @relation("AuditActorMember")
  tagAssignments             CustomerTag[]            @relation("CustomerTagAssigningMember")
  conversationTagAssignments ConversationTag[]        @relation("ConversationTagAssigningMember")
  tagAuditLogs               TagAuditLog[]            @relation("TagAuditActorMember")
  Campaign                   Campaign[]
  CampaignAuditLog           CampaignAuditLog[]

  @@unique([organizationId, profileId])
  @@map("members")
}

model Invitation {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  invitedByMemberId String?          @map("invited_by_member_id") @db.Uuid
  email             String
  role              WorkspaceRole
  team              String
  status            InvitationStatus @default(PENDING)
  invitedAt         DateTime         @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt        DateTime?        @map("accepted_at") @db.Timestamptz(6)
  expiresAt         DateTime?        @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  invitedByMember   Member?          @relation("InvitationInviter", fields: [invitedByMemberId], references: [id], onDelete: SetNull)
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email, status])
  @@map("invitations")
}

model Integration {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String                  @map("organization_id") @db.Uuid
  provider            IntegrationProvider
  providerName        String                  @map("provider_name")
  requiredAccountType String                  @map("required_account_type")
  permissionsHint     String                  @map("permissions_hint")
  accountName         String?                 @map("account_name")
  availableAccounts   Json                    @map("available_accounts")
  capabilities        IntegrationCapability[]
  status              IntegrationStatus       @default(DISCONNECTED)
  lastCheckedAt       DateTime?               @map("last_checked_at") @db.Timestamptz(6)
  connectionMetadata  Json?                   @map("connection_metadata")
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  credentials         IntegrationCredential?
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Campaign            Campaign[]

  @@unique([organizationId, provider])
  @@map("integrations")
}

model IntegrationCredential {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  integrationId    String       @unique @map("integration_id") @db.Uuid
  encryptedPayload String       @map("encrypted_payload")
  iv               String
  authTag          String       @map("auth_tag")
  keyVersion       Int          @default(1) @map("key_version")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  rotatedAt        DateTime?    @map("rotated_at") @db.Timestamptz(6)
  integration      Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("integration_credentials")
}

model Customer {
  id                        String                    @id
  organizationId            String                    @map("organization_id") @db.Uuid
  assignedMemberId          String?                   @map("assigned_member_id") @db.Uuid
  primaryConversationId     String?                   @unique @map("primary_conversation_id")
  avatarFallback            String?                   @map("avatar_fallback")
  avatarUrl                 String?                   @map("avatar_url")
  profileUpdatedAt          DateTime?                 @map("profile_updated_at") @db.Timestamptz(6)
  name                      String
  email                     String?
  phone                     String?
  location                  String?
  notes                     String?
  marketingConsentStatus    MarketingConsentStatus    @default(UNKNOWN) @map("marketing_consent_status")
  marketingConsentUpdatedAt DateTime?                 @map("marketing_consent_updated_at") @db.Timestamptz(6)
  marketingConsentSource    String?                   @map("marketing_consent_source")
  status                    ConversationStatus
  unreadCount               Int                       @default(0) @map("unread_count")
  lastInteractionAt         DateTime?                 @map("last_interaction_at") @db.Timestamptz(6)
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedMember            Member?                   @relation("CustomerAssignee", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  channelIdentities         CustomerChannelIdentity[]
  conversations             Conversation[]            @relation("CustomerConversations")
  notesEntries              CustomerNote[]
  orderRecords              Order[]
  organization              Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryConversation       Conversation?             @relation("CustomerPrimaryConversation", fields: [primaryConversationId], references: [id], onDelete: SetNull)
  tags                      CustomerTag[]
  invoices                  Invoice[]
  segmentMemberships        SegmentMembership[]
  CampaignRecipient         CampaignRecipient[]

  @@unique([organizationId, email])
  @@unique([organizationId, id])
  @@map("customers")
}

model CustomerChannelIdentity {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  customerId     String       @map("customer_id")
  channel        ChannelType
  handle         String
  externalId     String       @map("external_id")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, channel, externalId])
  @@map("customer_channel_identities")
}

model Conversation {
  id                     String                   @id
  organizationId         String                   @map("organization_id") @db.Uuid
  customerId             String                   @map("customer_id")
  assignedMemberId       String?                  @map("assigned_member_id") @db.Uuid
  channel                ChannelType
  status                 ConversationStatus
  previewText            String?                  @map("preview_text")
  unreadCount            Int                      @default(0) @map("unread_count")
  startedAt              DateTime?                @map("started_at") @db.Timestamptz(6)
  firstResponseAt        DateTime?                @map("first_response_at") @db.Timestamptz(6)
  resolvedAt             DateTime?                @map("resolved_at") @db.Timestamptz(6)
  lastMessageAt          DateTime?                @map("last_message_at") @db.Timestamptz(6)
  externalThreadId       String?                  @map("external_thread_id")
  createdAt              DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedMember         Member?                  @relation("ConversationAssignee", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  assignments            ConversationAssignment[]
  customer               Customer                 @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  messages               ConversationMessage[]
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  primaryConversationFor Customer?                @relation("CustomerPrimaryConversation")
  tags                   ConversationTag[]

  @@unique([organizationId, externalThreadId])
  @@map("conversations")
}

model ConversationMessage {
  id                String              @id
  organizationId    String              @map("organization_id") @db.Uuid
  conversationId    String              @map("conversation_id")
  senderMemberId    String?             @map("sender_member_id") @db.Uuid
  senderDisplayName String              @map("sender_display_name")
  direction         MessageDirection
  type              MessageType
  body              String
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  attachments       MessageAttachment[]
  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  senderMember      Member?             @relation("MessageSenderMember", fields: [senderMemberId], references: [id], onDelete: SetNull)

  @@map("conversation_messages")
}

model MessageAttachment {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  messageId      String              @map("message_id")
  kind           AttachmentKind
  fileName       String              @map("file_name")
  mimeType       String              @map("mime_type")
  storagePath    String?             @map("storage_path")
  publicUrl      String?             @map("public_url")
  sizeBytes      Int?                @map("size_bytes")
  width          Int?
  height         Int?
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  message        ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

model Tag {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  name             String
  description      String?
  color            String?
  target           TagTarget         @default(CUSTOMER)
  isArchived       Boolean           @default(false) @map("is_archived")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversationTags ConversationTag[]
  customerTags     CustomerTag[]
  auditLogs        TagAuditLog[]
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, target, name])
  @@map("tags")
}

model ConversationTag {
  organizationId     String              @map("organization_id") @db.Uuid
  conversationId     String              @map("conversation_id")
  tagId              String              @map("tag_id") @db.Uuid
  assignedByMemberId String?             @map("assigned_by_member_id") @db.Uuid
  source             TagAssignmentSource @default(MANUAL)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  assignedByMember   Member?             @relation("ConversationTagAssigningMember", fields: [assignedByMemberId], references: [id], onDelete: SetNull)
  conversation       Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tag                Tag                 @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

model CustomerTag {
  organizationId     String              @map("organization_id") @db.Uuid
  customerId         String              @map("customer_id")
  tagId              String              @map("tag_id") @db.Uuid
  assignedByMemberId String?             @map("assigned_by_member_id") @db.Uuid
  source             TagAssignmentSource @default(MANUAL)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  assignedByMember   Member?             @relation("CustomerTagAssigningMember", fields: [assignedByMemberId], references: [id], onDelete: SetNull)
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tag                Tag                 @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@map("customer_tags")
}

model ConversationAssignment {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  conversationId     String       @map("conversation_id")
  assignedMemberId   String       @map("assigned_member_id") @db.Uuid
  assignedByMemberId String?      @map("assigned_by_member_id") @db.Uuid
  assignedAt         DateTime     @default(now()) @map("assigned_at") @db.Timestamptz(6)
  unassignedAt       DateTime?    @map("unassigned_at") @db.Timestamptz(6)
  assignedByMember   Member?      @relation("AssigningMember", fields: [assignedByMemberId], references: [id], onDelete: SetNull)
  assignedMember     Member       @relation("AssignedMember", fields: [assignedMemberId], references: [id], onDelete: Cascade)
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("conversation_assignments")
}

model CustomerNote {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  customerId     String       @map("customer_id")
  authorMemberId String?      @map("author_member_id") @db.Uuid
  body           String
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  authorMember   Member?      @relation("CustomerNoteAuthor", fields: [authorMemberId], references: [id], onDelete: SetNull)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("customer_notes")
}

model SavedReply {
  id                String       @id
  organizationId    String       @map("organization_id") @db.Uuid
  createdByMemberId String?      @map("created_by_member_id") @db.Uuid
  title             String
  category          String
  shortcut          String
  message           String
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByMember   Member?      @relation("SavedReplyAuthor", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, shortcut])
  @@map("saved_replies")
}

model PublishingPost {
  id             String             @id
  organizationId String             @map("organization_id") @db.Uuid
  authorMemberId String?            @map("author_member_id") @db.Uuid
  caption        String
  mediaMetadata  Json?              @map("media_metadata")
  submitMode     PublishSubmitMode  @map("submit_mode")
  status         PublishingStatus
  scheduledFor   DateTime?          @map("scheduled_for") @db.Timestamptz(6)
  publishedAt    DateTime?          @map("published_at") @db.Timestamptz(6)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  authorMember   Member?            @relation("PublishingPostAuthor", fields: [authorMemberId], references: [id], onDelete: SetNull)
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targets        PublishingTarget[]

  @@map("publishing_posts")
}

model PublishingTarget {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  postId         String                 @map("post_id")
  provider       IntegrationProvider
  accountLabel   String?                @map("account_label")
  externalPostId String?                @map("external_post_id")
  status         PublishingTargetStatus
  scheduledFor   DateTime?              @map("scheduled_for") @db.Timestamptz(6)
  publishedAt    DateTime?              @map("published_at") @db.Timestamptz(6)
  errorMessage   String?                @map("error_message")
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  post           PublishingPost         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("publishing_targets")
}

model Order {
  id                  String           @id
  organizationId      String           @map("organization_id") @db.Uuid
  customerId          String           @map("customer_id")
  marketplace         OrderMarketplace
  orderNumber         String           @map("order_number")
  status              OrderStatus
  billingName         String           @map("billing_name")
  deliveryAddress     String           @map("delivery_address")
  paymentMethod       String           @map("payment_method")
  shippingFee         Decimal          @map("shipping_fee") @db.Decimal(12, 2)
  subtotalAmount      Decimal          @map("subtotal_amount") @db.Decimal(12, 2)
  totalAmount         Decimal          @map("total_amount") @db.Decimal(12, 2)
  trackingNumber      String?          @map("tracking_number")
  orderedAt           DateTime         @map("ordered_at") @db.Timestamptz(6)
  fulfillmentTimeline Json             @map("fulfillment_timeline")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer            Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice             Invoice?
  items               OrderItem[]
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id             String       @id
  organizationId String       @map("organization_id") @db.Uuid
  orderId        String       @map("order_id")
  sku            String
  name           String
  quantity       Int
  unitPrice      Decimal      @map("unit_price") @db.Decimal(12, 2)
  discountAmount Decimal      @map("discount_amount") @db.Decimal(12, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Invoice {
  id              String            @id
  organizationId  String            @map("organization_id") @db.Uuid
  orderId         String            @unique @map("order_id")
  customerId      String            @map("customer_id")
  invoiceNumber   String            @map("invoice_number")
  billedToName    String            @map("billed_to_name")
  billedToEmail   String?           @map("billed_to_email")
  billedToAddress String            @map("billed_to_address")
  billedToTaxId   String?           @map("billed_to_tax_id")
  notes           String?
  paymentMethod   String            @map("payment_method")
  shippingFee     Decimal           @map("shipping_fee") @db.Decimal(12, 2)
  subtotalAmount  Decimal           @map("subtotal_amount") @db.Decimal(12, 2)
  taxAmount       Decimal           @map("tax_amount") @db.Decimal(12, 2)
  taxRate         Decimal           @map("tax_rate") @db.Decimal(6, 4)
  totalAmount     Decimal           @map("total_amount") @db.Decimal(12, 2)
  issuedAt        DateTime          @map("issued_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  lineItems       InvoiceLineItem[]
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, invoiceNumber])
  @@map("invoices")
}

model InvoiceLineItem {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  invoiceId      String       @map("invoice_id")
  description    String
  quantity       Int
  amount         Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model WebhookEvent {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?             @map("organization_id") @db.Uuid
  provider        IntegrationProvider
  eventType       String              @map("event_type")
  externalEventId String              @map("external_event_id")
  payload         Json
  status          WebhookEventStatus  @default(PENDING)
  errorMessage    String?             @map("error_message")
  receivedAt      DateTime            @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt     DateTime?           @map("processed_at") @db.Timestamptz(6)
  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhook_events")
}

model AuditLog {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  actorType      AuditActorType @map("actor_type")
  actorMemberId  String?        @map("actor_member_id") @db.Uuid
  action         String
  entityType     String         @map("entity_type")
  entityId       String         @map("entity_id")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  actorMember    Member?        @relation("AuditActorMember", fields: [actorMemberId], references: [id], onDelete: SetNull)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Segment {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  name              String
  description       String?
  matchType         SegmentMatch        @default(ALL) @map("match_type")
  conditions        Json
  conditionsVersion Int                 @default(1) @map("conditions_version")
  isArchived        Boolean             @default(false) @map("is_archived")
  lastCalculatedAt  DateTime?           @map("last_calculated_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships       SegmentMembership[]
  Campaign          Campaign[]

  @@unique([organizationId, id])
  @@index([organizationId, isArchived])
  @@map("segments")
}

model SegmentMembership {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  segmentId      String       @map("segment_id") @db.Uuid
  customerId     String       @map("customer_id")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  segment        Segment      @relation(fields: [organizationId, segmentId], references: [organizationId, id], onDelete: Cascade)
  customer       Customer     @relation(fields: [organizationId, customerId], references: [organizationId, id], onDelete: Cascade)

  @@unique([segmentId, customerId])
  @@index([organizationId, segmentId])
  @@index([customerId])
  @@map("segment_memberships")
}

model TagAuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  actorMemberId  String?      @map("actor_member_id") @db.Uuid
  tagId          String       @map("tag_id") @db.Uuid
  action         String
  targetId       String?      @map("target_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  actorMember    Member?      @relation("TagAuditActorMember", fields: [actorMemberId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("tag_audit_logs")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  PARTIAL_FAILED
  FAILED
  CANCELLED

  @@map("campaign_status")
}

enum CampaignTargetType {
  BROADCAST
  TARGETED

  @@map("campaign_target_type")
}

enum CampaignMessageType {
  TEXT
  IMAGE

  @@map("campaign_message_type")
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@map("campaign_recipient_status")
}

model Campaign {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  name              String
  description       String?
  channel           IntegrationProvider @default(LINE)
  integrationId     String?             @map("integration_id") @db.Uuid
  targetType        CampaignTargetType  @default(BROADCAST) @map("target_type")
  segmentId         String?             @map("segment_id") @db.Uuid
  status            CampaignStatus      @default(DRAFT)
  timezone          String              @default("UTC")
  scheduledAt       DateTime?           @map("scheduled_at") @db.Timestamptz(6)
  createdByMemberId String?             @map("created_by_member_id")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration     Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  segment         Segment?     @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  createdByMember Member?      @relation(fields: [createdByMemberId], references: [id], onDelete: SetNull)

  messages   CampaignMessage[]
  batches    CampaignBatch[]
  recipients CampaignRecipient[]
  auditLogs  CampaignAuditLog[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignMessage {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  campaignId      String              @map("campaign_id") @db.Uuid
  type            CampaignMessageType
  textContent     String?             @map("text_content")
  imageUrl        String?             @map("image_url")
  previewImageUrl String?             @map("preview_image_url")
  orderIndex      Int                 @default(0) @map("order_index")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_messages")
}

model CampaignBatch {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  campaignId     String         @map("campaign_id") @db.Uuid
  idempotencyKey String         @map("idempotency_key")
  status         CampaignStatus @default(SENDING)
  errorMessage   String?        @map("error_message")
  recipientCount Int            @default(0) @map("recipient_count")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipients   CampaignRecipient[]

  @@unique([campaignId, idempotencyKey])
  @@map("campaign_batches")
}

model CampaignRecipient {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  campaignId     String                  @map("campaign_id") @db.Uuid
  batchId        String?                 @map("batch_id") @db.Uuid
  customerId     String                  @map("customer_id")
  lineUserId     String                  @map("line_user_id")
  status         CampaignRecipientStatus @default(PENDING)
  errorReason    String?                 @map("error_reason")
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  batch        CampaignBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@map("campaign_recipients")
}

model CampaignAuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  actorMemberId  String?  @map("actor_member_id") @db.Uuid
  action         String
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  actorMember  Member?      @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@map("campaign_audit_logs")
}
